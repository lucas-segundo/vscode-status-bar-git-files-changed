{
  "statusbar_command.commands": [
    {
      "id": "sbc_pr_size_monitor",
      "text": "🔄 Calc PR size...",
      "tooltip": "The size of the pull request compared to main",
      "alignment": "left",
      "priority": 100,
      "command": "workbench.view.scm",
      "scriptEvents": [
        "vscode.window.onDidChangeWindowState",
        "vscode.workspace.onDidChangeWorkspaceFolders",
        "require(require('path').join(vscode.workspace.workspaceFolders[0].uri.fsPath, '.vscode', 'pr-size-statusbar-git-events.cjs')).onDidOpenRepository",
        "require(require('path').join(vscode.workspace.workspaceFolders[0].uri.fsPath, '.vscode', 'pr-size-statusbar-git-events.cjs')).onDidChangeRepositoryState"
      ],
      "script": "const path = require('path');require(path.join(vscode.workspace.workspaceFolders[0].uri.fsPath, '.vscode', 'pr-size-statusbar.cjs'))(vscode, statusBarItem);"
    }
  ]
}
