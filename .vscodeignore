# Editor / local dev (not needed at runtime)
.vscode/**
.vscode-test/**

# TypeScript sources and maps (published code lives in out/)
src/**
**/tsconfig.json
**/*.map

# Install metadata (vsce does not ship devDependencies the same way; keep this lean)
node_modules/**

# Lockfiles
pnpm-lock.yaml
package-lock.json
yarn.lock

# Git and CI (not needed in the VSIX)
.git/**
.gitignore
.github/**

# Build output you do not ship
*.vsix

# OS / env / logs
.DS_Store
.env
.env.*
*.log
.pnpm-store/**

# ESLint and Prettier configs
.editorconfig
.prettier*
eslint.config.*
.eslintrc*

